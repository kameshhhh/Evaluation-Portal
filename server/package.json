{
  "name": "bitsathy-auth-server",
  "version": "1.0.0",
  "description": "Zero-Trust Identity-First Google Login System — Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "node src/scripts/initDatabase.js",
    "db:seed": "node src/scripts/seedRoles.js",
    "test": "jest --verbose",
    "test:identity": "jest --verbose src/auth/identity/__tests__/",
    "test:pemm": "jest --verbose src/entities/__tests__/ src/validators/__tests__/ src/lib/__tests__/ src/events/__tests__/ src/middleware/__tests__/",
    "db:migrate": "node src/scripts/runMigrations.js",
    "pemm:integrity": "node src/scripts/data-integrity-check.js",
    "pemm:audit": "node src/scripts/audit-verification.js"
  },
  "keywords": [
    "authentication",
    "google-oauth",
    "zero-trust",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "socket.io-client": "^4.8.3"
  }
}
