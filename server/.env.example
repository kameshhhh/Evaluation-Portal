# ============================================================
# BACKEND ENVIRONMENT CONFIGURATION — EXAMPLE FILE
# Copy to .env and fill in actual values
# ============================================================

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/auth_system
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET=minimum-32-character-secret-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_EXPIRY_HOURS=2

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Allowed domains (comma separated)
ALLOWED_DOMAINS=bitsathy.ac.in

# Logging
LOG_LEVEL=debug
